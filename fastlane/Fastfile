require 'securerandom'
require 'plist'
require 'fileutils'

default_platform(:ios)

platform :ios do
  desc "Build, archive, and export a signed white-label React Native/Expo app"
  lane :build_saas_app do |options|
    cert_path        = options[:cert_path]
    cert_password    = ENV['IOS_CERTIFICATE_PASSWORD']
    profile_path     = options[:profile_path]
    bundle_id        = options[:bundle_id]
    scheme_name      = options[:scheme_name]
    archive_path     = options[:archive_path]
    method           = options[:method] || "app-store"

    UI.message "🏗️ Archiving & Exporting IPA for Scheme: #{scheme_name} using P12: #{cert_path} and Profile: #{profile_path}"

    # Extract team ID and UUID from the mobileprovision file safely (preventing shell injection)
    plist_xml = sh("security", "cms", "-D", "-i", profile_path)
    plist = Plist.parse_xml(plist_xml)
    team_id = plist['TeamIdentifier'].first
    profile_uuid = plist['UUID']
    
    # Resolve code signing identity based on profile type (get-task-allow determines Development vs Distribution)
    get_task_allow = plist['Entitlements']['get-task-allow']
    code_sign_identity = get_task_allow ? "iPhone Developer" : "iPhone Distribution"

    UI.message "📲 Extracted from profile: Team ID = #{team_id}, UUID = #{profile_uuid}, Identity = #{code_sign_identity}"

    keychain_name = "app-signing-#{SecureRandom.hex(8)}"
    keychain_password = SecureRandom.hex(16)

    begin
      # Authenticate with App Store Connect if credentials are provided
      api_key = nil
      if ENV['APP_STORE_CONNECT_KEY_ID'] && ENV['APP_STORE_CONNECT_ISSUER_ID']
        UI.message "🔑 Authenticating with App Store Connect API Key..."
        if ENV['APP_STORE_CONNECT_KEY_FILEPATH'] && File.exist?(ENV['APP_STORE_CONNECT_KEY_FILEPATH'])
          api_key = app_store_connect_api_key(
            key_id: ENV['APP_STORE_CONNECT_KEY_ID'],
            issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
            key_filepath: ENV['APP_STORE_CONNECT_KEY_FILEPATH']
          )
        else
          UI.error "❌ App Store Connect credentials partially provided, but APP_STORE_CONNECT_KEY_FILEPATH is missing or invalid. skipping upload."
        end
      end

      # 1. Create a secure, temporary keychain
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: false,
        unlock: true,
        timeout: 3600
      )

      # 2. Import the certificate securely (uses internal secure execution)
      import_certificate(
        certificate_path: cert_path,
        certificate_password: cert_password,
        keychain_name: keychain_name,
        keychain_password: keychain_password
      )

      # 3. Install the provisioning profile
      install_provisioning_profile(path: profile_path)

      # 4. Safely configure signing settings directly on the project target
      update_code_signing_settings(
        path: "#{scheme_name}.xcodeproj",
        use_automatic_signing: false,
        team_id: team_id,
        bundle_identifier: bundle_id,
        code_sign_identity: code_sign_identity,
        profile_uuid: profile_uuid,
        targets: [scheme_name]
      )

      # 5. Build and Export IPA
      build_ios_app(
        workspace: "#{scheme_name}.xcworkspace",
        scheme: scheme_name,
        configuration: "Release",
        archive_path: archive_path,
        skip_build_archive: false,
        include_symbols: (method == "app-store"),
        output_directory: "./build",
        output_name: "#{scheme_name}.ipa",
        export_method: method,
        export_options: {
          signingStyle: "manual",
          teamID: team_id,
          uploadSymbols: (method == "app-store"),
          provisioningProfiles: {
            bundle_id => profile_uuid
          }
        }
      )

      # 6. Upload to target destination if API Key is set
      if api_key
        ios_track = ENV['IOS_TRACK'] || 'testflight-internal'
        changelog_text = ENV['APP_BUILD_CHANGELOG'] || "No changelog provided."

        if ios_track == 'app-store'
          UI.message "🚀 Uploading to App Store Connect (Production)..."
          upload_to_app_store(
            api_key: api_key,
            ipa: "./build/#{scheme_name}.ipa",
            skip_metadata: true,
            skip_screenshots: true,
            submit_for_review: false
          )
        elsif ios_track == 'testflight-external'
          UI.message "🚀 Uploading to TestFlight (External Testers)..."
          upload_to_testflight(
            api_key: api_key,
            ipa: "./build/#{scheme_name}.ipa",
            distribute_external: true,
            skip_waiting_for_build_processing: false,
            changelog: changelog_text
          )
        else
          UI.message "🚀 Uploading to TestFlight (Internal Testers)..."
          upload_to_testflight(
            api_key: api_key,
            ipa: "./build/#{scheme_name}.ipa",
            skip_waiting_for_build_processing: true,
            changelog: changelog_text
          )
        end
      else
        UI.message "⚠️ App Store Connect credentials not provided. Skipping upload."
      end
    ensure
      # Delete temporary keychain
      begin
        delete_keychain(name: keychain_name)
      rescue => e
        UI.message "Keychain cleanup skipped or failed: #{e.message}"
      end
      
      # Delete provisioning profile from the system
      begin
        if profile_uuid
          installed_profile = File.expand_path("~/Library/MobileDevice/Provisioning Profiles/#{profile_uuid}.mobileprovision")
          File.delete(installed_profile) if File.exist?(installed_profile)
        end
      rescue => e
        UI.message "Provisioning profile cleanup skipped: #{e.message}"
      end
    end
  end
end

platform :android do
  desc "Upload signed App Bundle (AAB) to Google Play Console"
  lane :upload_play_store do |options|
    changelog_text = ENV['APP_BUILD_CHANGELOG']
    if changelog_text && !changelog_text.strip.empty?
      UI.message "📝 Writing Android changelog to metadata files..."
      ['en-US', 'en-GB'].each do |locale|
        path = "metadata/android/#{locale}/changelogs"
        FileUtils.mkdir_p(path)
        File.write("#{path}/default.txt", changelog_text)
      end
    end

    upload_to_play_store(
      package_name: options[:package_name],
      aab: options[:aab_path],
      track: ENV['ANDROID_TRACK'] || 'internal',
      json_key: ENV['ANDROID_PUBLISH_JSON_PATH']
    )
  end
end
